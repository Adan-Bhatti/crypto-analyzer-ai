# =============================================================================
# AI-Based Cryptocurrency Market Behavior Analyzer and Risk Predictor
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# The application works without API keys (public endpoints only).

# Binance API (optional — public endpoints are used by default)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Data defaults
DEFAULT_COIN=BTCUSDT
DEFAULT_INTERVAL=1d
DEFAULT_LIMIT=500
